Options -Indexes
RewriteEngine On

# ── 1. Force HTTPS ──────────────────────────────────────────────────────────
RewriteCond %{HTTPS} off
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

# ── 2. Remove www (non-www is canonical) ────────────────────────────────────
RewriteCond %{HTTP_HOST} ^www\.moonlightautocare\.com$ [NC]
RewriteRule ^ https://moonlightautocare.com%{REQUEST_URI} [R=301,L]

# ── 3. Old PHP pages → 301 to relevant section (fixes Google 404s & not-indexed) ──
RewriteRule ^Index\.php$           https://moonlightautocare.com/ [R=301,L,NC]
RewriteRule ^Getting.Ready\.php$   https://moonlightautocare.com/ [R=301,L,NC]
RewriteRule ^Login\.php$           https://moonlightautocare.com/ [R=301,L,NC]
RewriteRule ^Contact/?$            https://moonlightautocare.com/#contact [R=301,L,NC]
RewriteRule ^Products\.php$        https://moonlightautocare.com/#services [R=301,L,NC]
RewriteRule ^About\.php$           https://moonlightautocare.com/#why [R=301,L,NC]
# Catch-all for any remaining old .php pages
RewriteRule ^[^/]+\.php$           https://moonlightautocare.com/ [R=301,L,NC]

# ── 5. Remove index.php and index.html from URL ─────────────────────────────
RewriteCond %{THE_REQUEST} /index\.(php|html)[\s?] [NC]
RewriteRule ^(.*)index\.(php|html)$ /$1 [R=301,L]

# ── 6. Trailing slash normalisation (no slash on files, slash on dirs) ───────
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_URI} (.+)/$
RewriteRule ^ %1 [R=301,L]

# ── 5. Security headers ──────────────────────────────────────────────────────
<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# ── 6. Cache static assets ───────────────────────────────────────────────────
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/svg+xml   "access plus 1 year"
  ExpiresByType image/png       "access plus 1 year"
  ExpiresByType image/ico       "access plus 1 year"
  ExpiresByType text/css        "access plus 1 month"
  ExpiresByType text/javascript "access plus 1 month"
  ExpiresByType text/html       "access plus 1 hour"
</IfModule>

# ── 7. Compress text responses ───────────────────────────────────────────────
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/javascript application/javascript
</IfModule>
